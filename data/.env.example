# Скопируй этот файл в ./data/.env и впиши свой токен.
# Это ЕДИНЫЙ конфиг: бот читает его и сам дописывает сюда токены (/auth).

# === Обязательно ===
# Токен бота от @BotFather
BOT_TOKEN=123456789:AA_замени_на_свой_токен

# === Необязательно ===
# HTTP- или SOCKS5-прокси для Telegram Bot API. Для локального SOCKS-входа
# Xray/3x-ui при network_mode: host можно использовать 127.0.0.1.
# TELEGRAM_PROXY=socks5://127.0.0.1:10808
# Прокси только для YouTube. Если не указан, используется TELEGRAM_PROXY.
# YT_PROXY=socks5://127.0.0.1:10808

# Токен Яндекс.Музыки. Проще получить прямо в боте: команда /auth -> Яндекс.
# YANDEX_TOKEN=

# Куки YouTube (нужны, если на VPS ловишь 403). Проще залить через /auth.
# YT_COOKIES=/data/cookies.txt

# Потолок качества видео (по умолчанию 1080). Для 4K поставь 2160.
# MAX_VIDEO_HEIGHT=1080

# Локальный Bot API server для файлов больше 50 МБ (до ~2 ГБ).
# LOCAL_BOT_API=http://host.docker.internal:8081
